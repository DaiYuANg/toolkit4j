{
  "name": "@kitty/root",
  "version": "1.0.0",
  "devDependencies": {
    "@changesets/cli": "^2.26.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.36.0",
    "eslint-plugin-react": "^7.32.2",
    "husky": "^8.0.3",
    "prettier": "^2.8.4",
    "rimraf": "^4.4.0"
  },
  "scripts": {
    "format": "prettier --write \"**/*.{js,ts,tsx,jsx,scss,html,md,json}\" --ignore-path .gitignore",
    "build": "cross-env NODE_ENV=production pnpm -r --parallel build",
    "prepare": "husky install",
    "clean": "rimraf ./node_modules ./**/*/node_modules ./**/*/dist ./**/*/build"
  }
}
