{
  "name": "@kitty/root",
  "version": "1.0.0",
  "devDependencies": {
    "eslint": "^8.33.0",
    "eslint-plugin-react": "^7.32.2",
    "prettier": "^2.8.3",
    "@changesets/cli": "^2.26.0",
    "husky": "^8.0.0",
    "cross-env": "^7.0.3",
    "rimraf": "^4.1.2"
  },
  "scripts": {
    "format": "prettier --write \"**/*.{js,ts,tsx,jsx,scss,html,md,json}\" --ignore-path .gitignore",
    "build": "cross-env NODE_ENV=production pnpm -r --parallel build",
    "prepare": "husky install"
  }
}
