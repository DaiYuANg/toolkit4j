# Copy to `.env` (gitignored) for local Maven Central publish. CI can inject the same keys as job `env` / secrets.
# Multi-line GPG armored key: use \n escapes inside quotes, or keep on one line per your dotenv tool.

# Sonatype Central user token (not your login password)
mavenCentralUsername=
mavenCentralPassword=

# In-memory signing (see https://vanniktech.github.io/gradle-maven-publish-plugin/central/#secrets)
signingInMemoryKey=
# signingInMemoryKeyId=
# signingInMemoryKeyPassword=

# Optional POM overrides (defaults exist in root build.gradle.kts)
# POM_URL=
# POM_SCM_URL=
# POM_SCM_CONNECTION=
# POM_SCM_DEV_CONNECTION=
# POM_DEVELOPER_ID=
# POM_DEVELOPER_NAME=
# POM_DEVELOPER_URL=
